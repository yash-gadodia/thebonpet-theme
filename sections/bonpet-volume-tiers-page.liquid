    font-weight: 400;
  }
  .tbp-vol-calc-saving-label {
    font-size: var(--tbp-text-xs);
    color: rgba(255,244,228,0.85);
    line-height: 1.3;
  }
  .tbp-vol-calc-note {
    font-size: var(--tbp-text-xs);
    color: rgba(255,244,228,0.72);
    line-height: 1.4;
    margin: 0;
  }

  .tbp-v3 .tbp-vol-table-title,
  .tbp-v3 .tbp-vol-faq-title {
    font-family: var(--tbp-font-display);
    font-size: clamp(1.75rem, 1.4rem + 1.2vw, 2.25rem);
    color: var(--tbp-primary);
    text-align: center;
    margin: 0 0 var(--tbp-space-5);
    font-weight: 400;
  }
  .tbp-vol-table-wrap {
    background: #fff;
    border-radius: var(--tbp-radius-md);
    overflow-x: auto;
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
  }
  .tbp-vol-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 560px;
  }
  .tbp-vol-table thead {
    background: var(--tbp-primary);
    color: var(--tbp-cream);
  }
  .tbp-vol-table th,
  .tbp-vol-table td {
    padding: var(--tbp-space-3) var(--tbp-space-4);
    text-align: left;
    font-size: var(--tbp-text-sm);
    border-bottom: 1px solid var(--tbp-cream-alt);
  }
  .tbp-vol-table thead th {
    font-weight: 700;
    font-size: var(--tbp-text-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-bottom: 0;
  }
  .tbp-vol-table tbody th {
    font-weight: 700;
    color: var(--tbp-primary);
  }
  .tbp-vol-table tbody tr.is-active {
    background: var(--tbp-cream-alt);
    box-shadow: inset 4px 0 0 var(--tbp-primary-mid);
  }
  .tbp-vol-table tbody tr.is-active td,
  .tbp-vol-table tbody tr.is-active th { color: var(--tbp-primary); }
  .tbp-vol-table tbody tr:last-child td,
  .tbp-vol-table tbody tr:last-child th { border-bottom: 0; }
  .tbp-vol-table-footnote {
    color: var(--tbp-text-mid);
