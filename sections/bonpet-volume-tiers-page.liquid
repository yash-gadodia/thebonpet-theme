{%- comment -%}
  V3 Volume Tiers Page - full content for /pages/volume-discounts.
  Display-only: no <form>, no AJAX to cart, no write actions. Calculator is pure local JS.
{%- endcomment -%}

<section class="tbp-v3 tbp-vol-page" aria-label="Volume discounts">
  <div class="tbp-container tbp-vol-hero">
    {%- if section.settings.eyebrow != blank -%}
      <p class="tbp-vol-eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    <h1 class="tbp-vol-title">{{ section.settings.heading | default: 'Save up to 40% on the meals they already love.' }}</h1>
    {%- if section.settings.lead != blank -%}
      <p class="tbp-vol-lead">{{ section.settings.lead }}</p>
    {%- endif -%}
    <div class="tbp-vol-hero-pills">
      <span class="tbp-vol-hero-pill">✅ Applied automatically at checkout</span>
      <span class="tbp-vol-hero-pill">✅ Stacks with Subscribe &amp; Save</span>
      <span class="tbp-vol-hero-pill">✅ No code needed</span>
    </div>
  </div>

  <div class="tbp-container tbp-vol-calc-wrap" data-tbp-vol-calc>
    <div class="tbp-vol-calc">
      <div class="tbp-vol-calc-head">
        <h2 class="tbp-vol-calc-title">Find your tier</h2>
        <p class="tbp-vol-calc-sub">Enter your packs per month (we pack 300g for dogs, 200g for cats). Your tier updates below.</p>
      </div>

      <div class="tbp-vol-calc-body">
        <div class="tbp-vol-calc-input-wrap">
          <label class="tbp-vol-calc-label" for="tbp-vol-calc-input">Packs per month</label>
          <div class="tbp-vol-calc-stepper">
            <button type="button" class="tbp-vol-calc-step" data-tbp-step="-1" aria-label="Decrease">−</button>
            <input id="tbp-vol-calc-input"
                   class="tbp-vol-calc-input"
                   type="number"
                   min="1"
                   max="500"
                   step="1"
                   value="30"
                   inputmode="numeric"
                   data-tbp-vol-calc-input
                   aria-describedby="tbp-vol-calc-hint">
            <button type="button" class="tbp-vol-calc-step" data-tbp-step="1" aria-label="Increase">+</button>
          </div>
          <p class="tbp-vol-calc-hint" id="tbp-vol-calc-hint">Quick picks:</p>
          <div class="tbp-vol-calc-profiles" role="group" aria-label="Common household profiles">
            <button type="button" class="tbp-vol-calc-profile" data-tbp-profile="15">🐱 1 cat (~15)</button>
            <button type="button" class="tbp-vol-calc-profile" data-tbp-profile="30">🐱🐱 2 cats (~30)</button>
            <button type="button" class="tbp-vol-calc-profile" data-tbp-profile="30">🐶 1 small dog (~30)</button>
            <button type="button" class="tbp-vol-calc-profile" data-tbp-profile="60">🐶 1 big dog (~60)</button>
            <button type="button" class="tbp-vol-calc-profile" data-tbp-profile="120">🐶🐶 Multi-dog (~120)</button>
            <button type="button" class="tbp-vol-calc-profile" data-tbp-profile="180">🏠 Foster / breeder (~180)</button>
          </div>
        </div>

        <div class="tbp-vol-calc-output">
          <div class="tbp-vol-calc-tier-pill" data-tbp-vol-calc-tier-pill>Tier 2</div>
          <p class="tbp-vol-calc-output-label">Your automatic savings:</p>
          <div class="tbp-vol-calc-savings">
            <div class="tbp-vol-calc-saving">
              <span class="tbp-vol-calc-saving-pct" data-tbp-vol-calc-sub>25%</span>
              <span class="tbp-vol-calc-saving-label">Subscribe &amp; Save (auto)</span>
            </div>
            <div class="tbp-vol-calc-saving">
              <span class="tbp-vol-calc-saving-pct" data-tbp-vol-calc-ot>15%</span>
              <span class="tbp-vol-calc-saving-label">One-time order</span>
            </div>
          </div>
          <p class="tbp-vol-calc-note">Final totals are confirmed at checkout. Discount is calculated on the pack subtotal; delivery fees apply as usual.</p>
        </div>
      </div>
    </div>
  </div>

  <div class="tbp-container">
    <h2 class="tbp-vol-table-title">All the tiers</h2>
    <div class="tbp-vol-table-wrap" role="region" aria-label="Volume discount tier table" tabindex="0">
      <table class="tbp-vol-table">
        <thead>
          <tr>
            <th scope="col">Packs / month</th>
            <th scope="col">Subscribe &amp; Save</th>
            <th scope="col">One-time order</th>
            <th scope="col">Who this fits</th>
          </tr>
        </thead>
        <tbody>
          <tr data-tbp-tier-row="1">
            <th scope="row">1 to 29</th>
            <td><strong>10% off</strong></td>
            <td>No extra tier discount</td>
            <td>1 cat, 1 small dog, or casual topper use</td>
          </tr>
          <tr data-tbp-tier-row="2">
            <th scope="row">30 to 59</th>
            <td><strong>25% off</strong></td>
            <td><strong>15% off</strong></td>
            <td>2 cats, 1 medium dog, or light multi-pet</td>
          </tr>
          <tr data-tbp-tier-row="3">
            <th scope="row">60 to 99</th>
            <td><strong>30% off</strong></td>
            <td><strong>20% off</strong></td>
            <td>1 big dog or multi-pet household</td>
          </tr>
          <tr data-tbp-tier-row="4">
            <th scope="row">100 to 149</th>
            <td><strong>35% off</strong></td>
            <td><strong>25% off</strong></td>
            <td>Multi-dog home, small foster setup</td>
          </tr>
          <tr data-tbp-tier-row="5">
            <th scope="row">150+</th>
            <td><strong>40% off</strong></td>
            <td><strong>30% off</strong></td>
            <td>Breeder, foster network, rescue partner</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="tbp-vol-table-footnote">Tier discounts apply automatically at checkout based on the total pack count in your order. No promo code needed.</p>
  </div>

  <div class="tbp-container">
    <h2 class="tbp-vol-faq-title">How the tier discount works</h2>
    <div class="tbp-vol-faq">
      <details class="tbp-vol-faq-item">
        <summary><span>Does the tier discount stack with Subscribe &amp; Save?</span><span class="tbp-vol-faq-chev" aria-hidden="true">+</span></summary>
        <div class="tbp-vol-faq-body">
          <p>Yes. Subscribe &amp; Save is a selling-plan price adjustment, not a cart-level automatic discount, so it applies to each subscription line item first. The tier discount then applies on the order subtotal. Both are calculated automatically at checkout.</p>
        </div>
      </details>
      <details class="tbp-vol-faq-item">
        <summary><span>Do I need a promo code?</span><span class="tbp-vol-faq-chev" aria-hidden="true">+</span></summary>
        <div class="tbp-vol-faq-body">
          <p>No code needed. Tiers trigger automatically based on pack count per order. If you see an existing promo code field empty, that is by design: the tier is already applied to your subtotal.</p>
        </div>
      </details>
      <details class="tbp-vol-faq-item">
        <summary><span>Does the tier apply to one-time orders too?</span><span class="tbp-vol-faq-chev" aria-hidden="true">+</span></summary>
        <div class="tbp-vol-faq-body">
          <p>Yes, from Tier 2 onwards (30+ packs). One-time bulk orders get a flat tier discount without Subscribe &amp; Save on top. Perfect for breeders and fosters who prefer not to subscribe.</p>
        </div>
      </details>
      <details class="tbp-vol-faq-item">
        <summary><span>Can I mix dog and cat packs to hit a tier?</span><span class="tbp-vol-faq-chev" aria-hidden="true">+</span></summary>
        <div class="tbp-vol-faq-body">
          <p>Yes. All Bon Pet meal packs (200g cats, 300g dogs) count toward the pack total. Bone broth and merch do not count.</p>
        </div>
      </details>
      <details class="tbp-vol-faq-item">
        <summary><span>I feed a rescue or foster network. Can we go beyond Tier 5?</span><span class="tbp-vol-faq-chev" aria-hidden="true">+</span></summary>
        <div class="tbp-vol-faq-body">
          <p>Drop us a message at hello@thebonpet.com. We run custom quotes for registered rescues, long-term fosters, and breeders who feed 200+ packs a month.</p>
        </div>
      </details>
    </div>
  </div>

  <div class="tbp-container tbp-vol-cta">
    <div class="tbp-vol-cta-card">
      <h2 class="tbp-vol-cta-title">{{ section.settings.cta_heading | default: 'Ready to feed the whole pack?' }}</h2>
      <p class="tbp-vol-cta-sub">{{ section.settings.cta_sub | default: 'Pick your proteins, pick your cadence. The tier discount is waiting at checkout.' }}</p>
      <div class="tbp-vol-cta-buttons">
        <a class="tbp-vol-cta-btn tbp-vol-cta-btn-dog" href="{{ section.settings.cta_dog_link | default: '/collections/dogs' }}">{{ section.settings.cta_dog_label | default: 'Shop Dog Meals 🐶' }}</a>
        <a class="tbp-vol-cta-btn tbp-vol-cta-btn-cat" href="{{ section.settings.cta_cat_link | default: '/collections/cats' }}">{{ section.settings.cta_cat_label | default: 'Shop Cat Meals 🐱' }}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .tbp-vol-page { padding: var(--tbp-space-7) 0 var(--tbp-space-9); background: var(--tbp-cream); }
  .tbp-vol-page > .tbp-container { margin-bottom: var(--tbp-space-8); }
  .tbp-vol-page > .tbp-container:last-child { margin-bottom: 0; }

