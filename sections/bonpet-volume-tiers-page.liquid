  }
  .tbp-v3 .tbp-vol-cta-title {
    font-family: var(--tbp-font-display);
    font-size: clamp(1.75rem, 1.4rem + 1.3vw, 2.5rem);
    color: var(--tbp-cream);
    margin: 0 0 var(--tbp-space-3);
    font-weight: 400;
    line-height: 1.15;
  }
  .tbp-vol-cta-sub {
    color: rgba(255,244,228,0.88);
    font-size: var(--tbp-text-base);
    margin: 0 auto var(--tbp-space-5);
    max-width: 520px;
    line-height: 1.5;
  }
  .tbp-vol-cta-buttons {
    display: flex;
    justify-content: center;
    gap: var(--tbp-space-3);
    flex-wrap: wrap;
  }
  .tbp-vol-cta-btn {
    display: inline-block;
    padding: 14px 28px;
    border-radius: var(--tbp-radius-pill);
    font-weight: 700;
    font-size: var(--tbp-text-base);
    text-decoration: none;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    min-width: 200px;
  }
  .tbp-vol-cta-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 16px rgba(0,0,0,0.22); }
  .tbp-vol-cta-btn-dog { background: var(--tbp-cream); color: var(--tbp-primary); }
  .tbp-vol-cta-btn-cat { background: transparent; color: var(--tbp-cream); border: 2px solid var(--tbp-cream); }
</style>

<script>
  (function () {
    var root = document.querySelector('[data-tbp-vol-calc]');
    if (!root) return;

    var TIERS = [
      { min: 1,   max: 29,  sub: 10, ot: 0,  label: 'Tier 1', oneTime: null },
      { min: 30,  max: 59,  sub: 25, ot: 15, label: 'Tier 2', oneTime: 15 },
      { min: 60,  max: 99,  sub: 30, ot: 20, label: 'Tier 3', oneTime: 20 },
      { min: 100, max: 149, sub: 35, ot: 25, label: 'Tier 4', oneTime: 25 },
      { min: 150, max: 9999, sub: 40, ot: 30, label: 'Tier 5', oneTime: 30 }
    ];

    var input = root.querySelector('[data-tbp-vol-calc-input]');
    var subOut = root.querySelector('[data-tbp-vol-calc-sub]');
    var otOut = root.querySelector('[data-tbp-vol-calc-ot]');
    var tierPill = root.querySelector('[data-tbp-vol-calc-tier-pill]');
    var stepBtns = root.querySelectorAll('[data-tbp-step]');
    var profileBtns = root.querySelectorAll('[data-tbp-profile]');
    var rows = document.querySelectorAll('[data-tbp-tier-row]');

    if (!input || !subOut || !otOut || !tierPill) return;

    function findTierIndex(n) {
      for (var i = 0; i < TIERS.length; i++) {
        if (n >= TIERS[i].min && n <= TIERS[i].max) return i;
      }
      return 0;
    }

    function update() {
      var n = parseInt(input.value, 10);
      if (isNaN(n) || n < 1) n = 1;
      if (n > 9999) n = 9999;
      var idx = findTierIndex(n);
      var t = TIERS[idx];
      subOut.textContent = t.sub + '%';
      otOut.textContent = t.oneTime === null ? '-' : t.ot + '%';
      tierPill.textContent = t.label;

      for (var i = 0; i < rows.length; i++) {
        if (i === idx) {
          rows[i].classList.add('is-active');
        } else {
          rows[i].classList.remove('is-active');
        }
      }
    }

    input.addEventListener('input', update);
    input.addEventListener('change', update);

    for (var i = 0; i < stepBtns.length; i++) {
      (function (btn) {
        btn.addEventListener('click', function () {
          var delta = parseInt(btn.getAttribute('data-tbp-step'), 10) || 0;
          var current = parseInt(input.value, 10) || 0;
          var next = current + delta;
          if (next < 1) next = 1;
          input.value = next;
          update();
        });
      })(stepBtns[i]);
    }

    for (var j = 0; j < profileBtns.length; j++) {
      (function (btn) {
        btn.addEventListener('click', function () {
          var v = parseInt(btn.getAttribute('data-tbp-profile'), 10);
          if (!isNaN(v) && v > 0) {
            input.value = v;
            update();
          }
        });
      })(profileBtns[j]);
    }

    update();
  })();
</script>

