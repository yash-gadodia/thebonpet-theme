{%- comment -%} V3 FAQ accordion — homepage subset, driven by blocks, emits FAQPage schema for rich snippets {%- endcomment -%}
{%- if section.blocks.size > 0 -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for block in section.blocks -%}
      {
        "@type": "Question",
        "name": {{ block.settings.question | json }},
        "acceptedAnswer": {
          "@type": "Answer",
          "text": {{ block.settings.answer | json }}
        }
      }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}

<section class="tbp-v3 tbp-section tbp-section-cream tbp-faq">
  <div class="tbp-container">
    <h2 class="tbp-text-center">{{ section.settings.heading }}</h2>

    <div class="tbp-faq-list">
      {%- for block in section.blocks -%}
        <details class="tbp-faq-item" {{ block.shopify_attributes }}>
          <summary>
            <span>{{ block.settings.question }}</span>
            <svg aria-hidden="true" viewBox="0 0 20 20" width="20" height="20"><path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <div class="tbp-faq-answer">{{ block.settings.answer }}</div>
        </details>
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_label != blank -%}
      <p class="tbp-text-center tbp-mt-6">
        <a href="{{ section.settings.cta_link }}" style="color: var(--tbp-primary); font-weight: 600; text-decoration: underline;">
          {{ section.settings.cta_label }} →
        </a>
      </p>
    {%- endif -%}
  </div>
</section>

<style>
  .tbp-faq { padding: var(--tbp-space-8) 0; }
  .tbp-faq-list { max-width: 820px; margin: 0 auto; display: flex; flex-direction: column; gap: var(--tbp-space-3); }
  .tbp-faq-item { background: var(--tbp-white); border-radius: var(--tbp-radius-md); padding: var(--tbp-space-4) var(--tbp-space-5); border: 1px solid var(--tbp-tan-mid); }
  .tbp-faq-item summary { cursor: pointer; display: flex; justify-content: space-between; align-items: center; font-weight: 600; color: var(--tbp-text-dark); list-style: none; }
  .tbp-faq-item summary::-webkit-details-marker { display: none; }
  .tbp-faq-item summary svg { transition: transform 0.2s; color: var(--tbp-primary); flex-shrink: 0; margin-left: var(--tbp-space-3); }
  .tbp-faq-item[open] summary svg { transform: rotate(180deg); }
  .tbp-faq-answer { color: var(--tbp-text-mid); padding-top: var(--tbp-space-3); line-height: 1.7; }
</style>

{% schema %}
{
  "name": "TBP FAQ",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently Asked Questions" },
    { "type": "text", "id": "cta_label", "label": "Footer link label", "default": "Still have questions? Learn More" },
    { "type": "url", "id": "cta_link", "label": "Footer link URL" }
  ],
  "max_blocks": 12,
  "blocks": [
    {
      "type": "qa",
      "name": "Q&A",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "textarea", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "TBP FAQ",
      "blocks": [
        { "type": "qa", "settings": { "question": "How long can your meals be stored in the freezer?", "answer": "Our meals can be stored in the freezer for up to 1 year from the date of manufacture. Each pack is labeled with a Best Before date, so be sure to check it for guidance." } },
        { "type": "qa", "settings": { "question": "How are your meals delivered?", "answer": "Our meals are delivered through cold-chain delivery, ensuring they remain frozen from the time of manufacture until they reach your doorstep. You can select a 4-hour delivery window when placing your order. The driver will make up to 3 attempts to deliver your furkid's meals if you're unavailable." } },
        { "type": "qa", "settings": { "question": "How do I transition my pet to The Bon Pet meals?", "answer": "We recommend a gradual transition, especially if your pet is currently on a kibble diet. Start by mixing a small portion of our meals with their current food and increase the ratio over 3 to 5 days. Monitor your pet's stool throughout the process. If you encounter any issues or have concerns, feel free to contact us on WhatsApp for tailored advice." } },
        { "type": "qa", "settings": { "question": "My pet has allergies. What should I do?", "answer": "All our meals are made with single-protein sources to minimise allergy risks, and they do not contain artificial preservatives, colours, or fillers. If your pet has known allergies, please reach out to us on WhatsApp with details so we can help recommend a suitable meal plan." } },
        { "type": "qa", "settings": { "question": "Can I cook or heat your meals?", "answer": "We do not recommend cooking or heating our meals as this can alter the nutrient profile and reduce the quality of the food. Serve the meals at room temperature for the best experience." } }
      ]
    }
  ]
}
{% endschema %}
