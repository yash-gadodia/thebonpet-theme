{%- comment -%} V3 Founder team  -  cards with names, roles, photos {%- endcomment -%}
<section class="tbp-v3 tbp-section tbp-section-cream tbp-founder-team" aria-label="Our team">
  <div class="tbp-container">
    <div class="tbp-founder-team-inner">
      {%- if section.settings.heading != blank -%}
        <h2 class="tbp-founder-team-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      <div class="tbp-founder-team-grid">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'team_member' -%}
              <div class="tbp-founder-team-card">
                <div class="tbp-founder-team-photo">
                  {%- if block.settings.photo != blank -%}
                    <img
                      src="{{ block.settings.photo | image_url: width: 400 }}"
                      alt="{{ block.settings.name | escape }}"
                      loading="lazy"
                      class="tbp-founder-team-photo-img"
                    >
                  {%- else -%}
                    <div class="tbp-founder-team-photo-placeholder">
                      <span>{{ block.settings.name | split: ' ' | map: 'size: 1' | join: '' }}</span>
                    </div>
                  {%- endif -%}
                </div>
                <div class="tbp-founder-team-info">
                  {%- if block.settings.name != blank -%}
                    <h3 class="tbp-founder-team-name">{{ block.settings.name }}</h3>
                  {%- endif -%}
                  {%- if block.settings.role != blank -%}
                    <p class="tbp-founder-team-role">{{ block.settings.role }}</p>
                  {%- endif -%}
                  {%- if block.settings.bio != blank -%}
                    <p class="tbp-founder-team-bio">{{ block.settings.bio }}</p>
                  {%- endif -%}
                </div>
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  .tbp-founder-team { padding: var(--tbp-space-8) 0; }
  .tbp-founder-team-inner { max-width: 1200px; margin: 0 auto; }
  .tbp-founder-team-heading {
    font-family: var(--tbp-font-display);
    font-size: clamp(2rem, 1.5rem + 1.5vw, 2.75rem);
    line-height: 1.1;
    margin: 0 0 var(--tbp-space-7);
    text-align: center;
    color: var(--tbp-text-dark);
  }
  .tbp-founder-team-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--tbp-space-6);
  }
  @media (min-width: 640px) {
    .tbp-founder-team-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .tbp-founder-team-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .tbp-founder-team-card {
    display: flex;
    flex-direction: column;
    text-align: center;
  }
  .tbp-founder-team-photo {
    margin-bottom: var(--tbp-space-4);
    border-radius: var(--tbp-radius-md);
    overflow: hidden;
    aspect-ratio: 1;
    background: var(--tbp-white);
  }
  .tbp-founder-team-photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .tbp-founder-team-photo-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--tbp-primary) 0%, var(--tbp-primary-light) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--tbp-white);
    font-size: 2.5rem;
    font-weight: 700;
  }
  .tbp-founder-team-info {
    flex: 1;
  }
  .tbp-founder-team-name {
    font-size: var(--tbp-text-lg);
    font-weight: 700;
    margin: 0 0 var(--tbp-space-1);
    color: var(--tbp-text-dark);
  }
  .tbp-founder-team-role {
    font-size: var(--tbp-text-sm);
    color: var(--tbp-primary);
    font-weight: 600;
    margin: 0 0 var(--tbp-space-2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .tbp-founder-team-bio {
    font-size: var(--tbp-text-base);
    color: var(--tbp-text-mid);
    line-height: 1.5;
    margin: 0;
  }
</style>

{% schema %}
{
  "name": "TBP Founder Team",
  "settings": [
