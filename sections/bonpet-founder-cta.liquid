{%- comment -%} V3 Founder CTA  -  final call to action (trial pack) {%- endcomment -%}
<section class="tbp-v3 tbp-section tbp-section-dark tbp-founder-cta" aria-label="Call to action">
  <div class="tbp-container">
    <div class="tbp-founder-cta-inner">
      {%- if section.settings.heading != blank -%}
        <h2 class="tbp-founder-cta-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="tbp-founder-cta-subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      <div class="tbp-founder-cta-buttons">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'cta_button' -%}
              {%- if block.settings.label != blank -%}
                <a href="{{ block.settings.link }}" class="tbp-founder-cta-button">
                  {{ block.settings.label }}
                </a>
              {%- endif -%}
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  .tbp-founder-cta { padding: var(--tbp-space-9) 0; }
  .tbp-founder-cta-inner {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }
  .tbp-founder-cta-heading {
    font-family: var(--tbp-font-display);
    font-size: clamp(2rem, 1.5rem + 1.5vw, 2.75rem);
    line-height: 1.1;
    margin: 0 0 var(--tbp-space-3);
    color: var(--tbp-white);
  }
  .tbp-founder-cta-subheading {
    font-size: var(--tbp-text-lg);
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.6;
    margin: 0 0 var(--tbp-space-6);
  }
  .tbp-founder-cta-buttons {
    display: flex;
    flex-direction: column;
    gap: var(--tbp-space-3);
    justify-content: center;
  }
  @media (min-width: 640px) {
    .tbp-founder-cta-buttons {
      flex-direction: row;
      gap: var(--tbp-space-4);
    }
  }
  .tbp-founder-cta-button {
    display: inline-block;
    padding: var(--tbp-space-3) var(--tbp-space-5);
    background: var(--tbp-white);
    color: var(--tbp-primary);
    font-weight: 700;
    font-size: var(--tbp-text-base);
    border-radius: var(--tbp-radius-sm);
    text-decoration: none;
    text-align: center;
    transition: all 0.2s ease;
    border: 2px solid var(--tbp-white);
    letter-spacing: 0.02em;
  }
  .tbp-founder-cta-button:hover {
    background: transparent;
    color: var(--tbp-white);
    transform: translateY(-2px);
  }
  @media (max-width: 639px) {
    .tbp-founder-cta-button {
      padding: var(--tbp-space-4) var(--tbp-space-4);
      font-size: var(--tbp-text-sm);
    }
  }
</style>

{% schema %}
{
  "name": "TBP Founder CTA",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Ready to feed them like family?" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Start with our trial pack. Get 5 different proteins (dogs) or 4 different proteins (cats). Let your furkid decide their favourite." }
  ],
  "blocks": [
    {
      "name": "CTA button",
      "type": "cta_button",
      "settings": [
        { "type": "text", "id": "label", "label": "Button label" },
        { "type": "url", "id": "link", "label": "Button link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "TBP Founder CTA",
      "blocks": [
        {
          "type": "cta_button",
          "settings": {
            "label": "Shop Dog Trial 🐶",
            "link": "shopify://products/gently-cooked-trial-packs-for-dog"
          }
        },
        {
          "type": "cta_button",
          "settings": {
            "label": "Shop Cat Trial 🐱",
            "link": "shopify://products/gently-cooked-trial-packs-for-cats"
          }
        }
      ]
    }
  ]
}
{% endschema %}
