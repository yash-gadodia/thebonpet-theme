{%- comment -%} V3 Product Grid — split by dogs + cats, badge derived per protein {%- endcomment -%}
<section class="tbp-v3 tbp-section tbp-section-cream tbp-prod-grid">
  <div class="tbp-container">
    <h2 class="tbp-text-center">{{ section.settings.heading }}</h2>
    <p class="tbp-text-center tbp-mb-6" style="color: var(--tbp-text-mid);">{{ section.settings.subheading }}</p>

{%- comment -%} Dogs group - try setting, then handles in order {%- endcomment -%}
    {%- assign dog_collection = section.settings.dog_collection -%}
    {%- if dog_collection == blank or dog_collection.products.size == 0 -%}
      {%- assign dog_collection = collections.dogs -%}
    {%- endif -%}
    {%- if dog_collection == blank or dog_collection.products.size == 0 -%}
      {%- assign dog_collection = collections['gently-cooked-for-dogs'] -%}
    {%- endif -%}
    {%- if dog_collection != blank and dog_collection.products.size > 0 -%}
      <div class="tbp-prod-group">
        <div class="tbp-prod-group-head">
          <h3>🐶 For Dogs</h3>
          <a href="{{ dog_collection.url }}" class="tbp-prod-group-all">Shop all dog meals →</a>
        </div>
        <div class="tbp-products">
          {%- for product in dog_collection.products limit: section.settings.product_limit -%}
            {% render 'bonpet-product-card', product: product, default_badge: 'Free-Range' %}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} Cats group - try setting, then handles in order {%- endcomment -%}
    {%- assign cat_collection = section.settings.cat_collection -%}
    {%- if cat_collection == blank or cat_collection.products.size == 0 -%}
      {%- assign cat_collection = collections.cats -%}
    {%- endif -%}
    {%- if cat_collection == blank or cat_collection.products.size == 0 -%}
      {%- assign cat_collection = collections['gently-cooked-for-cats'] -%}
    {%- endif -%}
    {%- if cat_collection != blank and cat_collection.products.size > 0 -%}
      <div class="tbp-prod-group">
        <div class="tbp-prod-group-head">
          <h3>🐱 For Cats</h3>
          <a href="{{ cat_collection.url }}" class="tbp-prod-group-all">Shop all cat meals →</a>
        </div>
        <div class="tbp-products">
          {%- for product in cat_collection.products limit: section.settings.product_limit -%}
            {% render 'bonpet-product-card', product: product, default_badge: 'Free-Range' %}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- if dog_collection == blank and cat_collection == blank -%}
      <p class="tbp-text-center" style="color: var(--tbp-text-mid);">
        Select dog and cat collections in the theme editor to display products.
      </p>
    {%- endif -%}
  </div>
</section>

<style>
  .tbp-prod-grid { padding: var(--tbp-space-8) 0; }
  .tbp-prod-group { margin-bottom: var(--tbp-space-8); }
  .tbp-prod-group:last-child { margin-bottom: 0; }
  .tbp-prod-group-head {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: var(--tbp-space-5); flex-wrap: wrap; gap: var(--tbp-space-3);
  }
  .tbp-prod-group-head h3 {
    margin: 0; font-size: var(--tbp-text-2xl); color: var(--tbp-primary);
  }
  .tbp-prod-group-all {
    color: var(--tbp-primary); font-weight: 600; text-decoration: none;
    font-size: var(--tbp-text-sm);
  }
  .tbp-prod-group-all:hover { text-decoration: underline; }

  .tbp-products {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--tbp-space-3);
  }
  @media (min-width: 640px) { .tbp-products { grid-template-columns: repeat(3, 1fr); gap: var(--tbp-space-4); } }
  @media (min-width: 1024px) { .tbp-products { grid-template-columns: repeat(4, 1fr); gap: var(--tbp-space-5); } }

  .tbp-prod-card {
    background: var(--tbp-white); border-radius: var(--tbp-radius-md);
    overflow: hidden; display: flex; flex-direction: column;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    border: 1px solid rgba(0,0,0,0.04);
  }
  .tbp-prod-card:hover { transform: translateY(-4px); box-shadow: var(--tbp-shadow-md); }
  .tbp-prod-card-media {
    aspect-ratio: 1 / 1;
    background: var(--tbp-cream-alt);
    display: flex; align-items: center; justify-content: center;
    padding: var(--tbp-space-3);
    overflow: hidden;
  }
  .tbp-prod-card-media img {
    max-width: 100%; max-height: 100%;
    width: auto; height: auto;
    object-fit: contain;
    display: block;
    transition: transform 0.3s ease;
  }
  .tbp-prod-card:hover .tbp-prod-card-media img { transform: scale(1.04); }
  .tbp-prod-card-body {
    padding: var(--tbp-space-4);
    display: flex; flex-direction: column; gap: var(--tbp-space-2);
    flex: 1;
  }
  .tbp-prod-badge {
    align-self: flex-start; background: var(--tbp-tan); color: var(--tbp-text-dark);
    font-size: 0.7rem; padding: 3px 10px; border-radius: var(--tbp-radius-pill);
    text-transform: uppercase; letter-spacing: 0.06em; font-weight: 700; margin: 0;
  }
  .tbp-prod-card-body h4 {
    margin: 0;
    font-size: var(--tbp-text-base);
    line-height: 1.3;
    font-weight: 700;
  }
  .tbp-prod-card-body h4 a { color: var(--tbp-text-dark); text-decoration: none; }
  .tbp-prod-card-body h4 a:hover { color: var(--tbp-primary); }
  .tbp-prod-rating { display: flex; align-items: center; gap: 6px; margin: 0; font-size: 0.75rem; color: var(--tbp-text-mid); }
  .tbp-prod-stars { color: #FFB400; letter-spacing: 1px; font-size: 0.85rem; }
  .tbp-prod-rating-copy { font-weight: 500; }
  .tbp-prod-price {
    font-size: var(--tbp-text-lg);
    font-weight: 700; color: var(--tbp-primary); margin: 0;
    font-family: var(--tbp-font-body);
  }
  .tbp-prod-pack { font-size: 0.7rem; color: var(--tbp-text-mid); font-weight: 500; margin-left: 4px; }
  .tbp-prod-learn { font-size: 0.75rem; color: var(--tbp-text-mid); text-decoration: none; line-height: 1.4; }
  .tbp-prod-learn:hover { color: var(--tbp-primary); text-decoration: underline; }
  .tbp-prod-form { margin-top: auto; padding-top: var(--tbp-space-3); }
  .tbp-prod-form .tbp-btn { font-size: var(--tbp-text-sm); min-height: 42px; padding: 10px var(--tbp-space-4); }
  /* Mobile card trim: drop rating + learn-link + pack-size to compact the grid */
  @media (max-width: 639px) {
    .tbp-prod-card-body { padding: var(--tbp-space-3); gap: 6px; }
    .tbp-prod-card-body h4 { font-size: var(--tbp-text-sm); }
    .tbp-prod-rating { display: none; }
    .tbp-prod-learn { display: none; }
    .tbp-prod-pack { display: none; }
    .tbp-prod-form .tbp-btn { font-size: 0.8rem; min-height: 38px; padding: 8px var(--tbp-space-3); }
  }
</style>

{% schema %}
{
  "name": "TBP Product Grid",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our most-loved meals" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Complete & balanced. Single-protein. Loved by 865+ Singapore pawrents." },
    { "type": "collection", "id": "dog_collection", "label": "Dog collection" },
    { "type": "collection", "id": "cat_collection", "label": "Cat collection" },
    { "type": "range", "id": "product_limit", "label": "Max products per group", "min": 2, "max": 12, "step": 1, "default": 4 }
  ],
  "presets": [ { "name": "TBP Product Grid" } ]
}
{% endschema %}
