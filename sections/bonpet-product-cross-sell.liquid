{%- comment -%}
  V3.7 PDP Cross-sell / Bundle upsell strip.
  Goal: push cart toward $80 ($4 shipping) or $100 (free) tiers by surfacing
  complementary proteins + trial pack below the main ATC.
  Display-only Liquid + vanilla JS AJAX add-to-cart. No new form element.
{%- endcomment -%}

{%- if product != blank and section.blocks.size > 0 -%}
<section class="tbp-v3 tbp-pdp-cross" aria-label="Bundle suggestions">
  <div class="tbp-container">
    <div class="tbp-pdp-cross-head">
      {%- if section.settings.heading != blank -%}
        <h2 class="tbp-pdp-cross-title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subhead != blank -%}
        <p class="tbp-pdp-cross-sub">{{ section.settings.subhead }}</p>
      {%- endif -%}
    </div>

    <div class="tbp-pdp-cross-grid" role="list">
      {%- for block in section.blocks -%}
        {%- assign xp = block.settings.product -%}
        {%- if xp != blank and xp.available -%}
          <article class="tbp-pdp-cross-card" role="listitem" {{ block.shopify_attributes }}>
            <a class="tbp-pdp-cross-link" href="{{ xp.url }}" aria-label="{{ xp.title | escape }}">
              {%- if xp.featured_image -%}
                <img
                  class="tbp-pdp-cross-img"
                  src="{{ xp.featured_image | image_url: width: 240 }}"
                  alt=""
                  loading="lazy"
                  width="120"
                  height="120"
                >
              {%- endif -%}
              <div class="tbp-pdp-cross-body">
                {%- if block.settings.badge != blank -%}
                  <span class="tbp-pdp-cross-badge">{{ block.settings.badge }}</span>
                {%- endif -%}
                <p class="tbp-pdp-cross-name">{{ xp.title | truncate: 46, '...' }}</p>
                <p class="tbp-pdp-cross-price">
                  {%- if xp.compare_at_price > xp.price -%}
                    <s class="tbp-pdp-cross-compare">{{ xp.compare_at_price | money }}</s>
                  {%- endif -%}
                  <strong>{{ xp.price | money }}</strong>
                </p>
              </div>
            </a>
            <button
              type="button"
              class="tbp-pdp-cross-add"
              data-tbp-cross-add="{{ xp.selected_or_first_available_variant.id }}"
              data-tbp-cross-name="{{ xp.title | escape }}"
              {% if xp.selected_or_first_available_variant == blank or xp.selected_or_first_available_variant.available == false %}disabled{% endif %}
            >
              {{ section.settings.add_label | default: 'Add to cart' }}
            </button>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.footer_note != blank -%}
      <p class="tbp-pdp-cross-foot">{{ section.settings.footer_note }}</p>
    {%- endif -%}
  </div>
</section>

<script>
(function () {
  var root = document.currentScript && document.currentScript.previousElementSibling;
  var grid = document.querySelector('.tbp-pdp-cross-grid');
  if (!grid) return;
  grid.addEventListener('click', function (e) {
    var btn = e.target.closest('[data-tbp-cross-add]');
    if (!btn || btn.hasAttribute('disabled')) return;
    e.preventDefault();
    var id = btn.getAttribute('data-tbp-cross-add');
    if (!id) return;
    var originalLabel = btn.textContent;
    btn.setAttribute('disabled', '');
    btn.textContent = 'Adding…';
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
      body: JSON.stringify({ id: id, quantity: 1 })
    })
    .then(function (r) { return r.ok ? r.json() : Promise.reject(r); })
    .then(function () {
      btn.textContent = 'Added ✓';
      var drawer = document.querySelector('cart-drawer');
      if (drawer && typeof drawer.open === 'function') {
        try { drawer.open(); } catch (e) {}
      } else {
        window.dispatchEvent(new CustomEvent('cart:updated'));
      }
      setTimeout(function () { btn.textContent = originalLabel; btn.removeAttribute('disabled'); }, 1800);
    })
    .catch(function () {
      btn.textContent = 'Try again';
      setTimeout(function () { btn.textContent = originalLabel; btn.removeAttribute('disabled'); }, 1800);
    });
  });
})();
</script>

<style>
  .tbp-pdp-cross { padding: var(--tbp-space-6) 0 var(--tbp-space-4); background: var(--tbp-cream, #FFF4E4); }
  .tbp-pdp-cross-head { text-align: center; margin-bottom: var(--tbp-space-5); }
  .tbp-pdp-cross-title {
    font-family: var(--tbp-font-display, inherit);
    color: var(--tbp-primary, #16433D);
    font-size: clamp(1.5rem, 1.2rem + 1vw, 2.25rem);
    margin: 0 0 var(--tbp-space-2);
  }
  .tbp-pdp-cross-sub {
    color: var(--tbp-text-mid, #555);
    max-width: 560px; margin: 0 auto; font-size: 15px;
  }

  .tbp-pdp-cross-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--tbp-space-3);
  }
  @media (min-width: 720px) {
    .tbp-pdp-cross-grid { grid-template-columns: repeat(3, 1fr); gap: var(--tbp-space-4); }
  }
  @media (min-width: 1024px) {
    .tbp-pdp-cross-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .tbp-pdp-cross-card {
    background: var(--tbp-white, #fff);
    border: 1px solid var(--tbp-tan, #EDDDC0);
    border-radius: var(--tbp-radius-md, 14px);
    padding: var(--tbp-space-3);
    display: flex; flex-direction: column; gap: var(--tbp-space-2);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .tbp-pdp-cross-card:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,0,0,0.08); }

  .tbp-pdp-cross-link {
    text-decoration: none; color: inherit;
    display: flex; flex-direction: column; gap: var(--tbp-space-2);
    flex: 1;
  }
  .tbp-pdp-cross-img {
    width: 100%; aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: var(--tbp-radius-sm, 10px);
  }
  .tbp-pdp-cross-body { display: flex; flex-direction: column; gap: 4px; }
  .tbp-pdp-cross-badge {
    align-self: flex-start;
    background: var(--tbp-primary, #16433D); color: var(--tbp-white, #fff);
    padding: 2px 8px; border-radius: 999px;
    font-size: 10px; font-weight: 700; letter-spacing: 0.04em;
  }
  .tbp-pdp-cross-name {
    margin: 0; font-size: 14px; font-weight: 600;
    color: var(--tbp-text-dark, #1e1e1e); line-height: 1.3;
  }
  .tbp-pdp-cross-price {
    margin: 0; font-size: 15px; font-weight: 700;
    color: var(--tbp-primary, #16433D);
    display: flex; align-items: baseline; gap: 6px;
  }
  .tbp-pdp-cross-compare {
    font-size: 12px; color: var(--tbp-text-mid, #888);
    font-weight: 400;
  }

  .tbp-pdp-cross-add {
    background: var(--tbp-primary, #16433D); color: var(--tbp-white, #fff);
    border: 0; padding: 9px 14px;
    border-radius: var(--tbp-radius-pill, 999px);
    font-family: inherit; font-weight: 700; font-size: 13px;
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .tbp-pdp-cross-add:hover:not([disabled]) { background: var(--tbp-primary-deep, #03443C); }
  .tbp-pdp-cross-add[disabled] { opacity: 0.6; cursor: wait; }

  .tbp-pdp-cross-foot {
    text-align: center; margin: var(--tbp-space-4) 0 0;
    font-size: 12px; color: var(--tbp-text-mid, #666);
  }
</style>

{%- endif -%}

{% schema %}
{
  "name": "TBP PDP Cross-sell",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Complete the bundle 🍖" },
    { "type": "textarea", "id": "subhead", "label": "Subheading", "default": "Bundle 3+ proteins and unlock FREE delivery at $100 (or $4 from $80). Variety your furkid will love." },
    { "type": "text", "id": "add_label", "label": "Add-to-cart label", "default": "Add to cart" },
    { "type": "textarea", "id": "footer_note", "label": "Footer note (optional)", "default": "Pro tip: 4 proteins = more rotation, less picky-eating, and FREE cold-chain delivery." }
  ],
  "blocks": [{
    "type": "product_card",
    "name": "Product card",
    "settings": [
      { "type": "product", "id": "product", "label": "Product" },
      { "type": "text", "id": "badge", "label": "Badge (optional)", "info": "Short label e.g. 'BESTSELLER', 'NEW', 'BUNDLE'" }
    ]
  }],
  "max_blocks": 6,
  "presets": [{
    "name": "TBP PDP Cross-sell",
    "settings": {}
  }]
}
{% endschema %}
