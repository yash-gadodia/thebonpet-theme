        "faq": {
            "type": "bonpet-faq",
            "blocks": {
                "q1": {
                    "type": "qa",
                    "settings": {
                        "question": "Is fresh pet food worth it compared to kibble?",
                        "answer": "Fresh gently cooked meals are more digestible, retain heat-sensitive nutrients (taurine, B vitamins) that kibble's extrusion destroys, and typically produce better stool quality, coat shine, and weight management. Start with a free trial pack and see the difference in 2 weeks."
                    }
                },
                "q2": {
                    "type": "qa",
                    "settings": {
                        "question": "How do I transition my pet to The Bon Pet?",
                        "answer": "Gradual 3-5 day switch: Day 1-2 at 25% new / 75% old \u2192 Day 3-4 at 50/50 \u2192 Day 5+ at 100% new. Monitor stool throughout. If your pet is on kibble, this transition is especially important. WhatsApp us for tailored advice."
                    }
                },
                "q3": {
                    "type": "qa",
                    "settings": {
                        "question": "How long do frozen meals last?",
                        "answer": "Frozen: up to 1 year from manufacture (Best Before printed on each pack). Thawed: 2-3 days in a sealed container in the fridge. Never refreeze once thawed."
                    }
                },
                "q4": {
                    "type": "qa",
                    "settings": {
                        "question": "My pet has allergies. Can they eat this?",
                        "answer": "All recipes are single-protein to minimise allergy risk. No artificial preservatives, colours, or fillers. If allergies are known, WhatsApp us with details and we'll recommend a suitable protein (Kangaroo is a popular novel protein for sensitivities)."
                    }
                },
                "q5": {
                    "type": "qa",
                    "settings": {
                        "question": "Do you deliver across Singapore?",
                        "answer": "Yes, island-wide cold-chain delivery. Pick a 4-hour delivery window at checkout. FREE delivery over $100, $4 from $80 to $99.99, $9 under $80. Same tiers for cat and dog. Driver makes up to 3 delivery attempts."
                    }
                },
                "q6": {
                    "type": "qa",
                    "settings": {
                        "question": "Can I pause or cancel my subscription?",
                        "answer": "Yes, anytime. Log in to your account or WhatsApp us. Cadences from weekly up to 6-weekly (the 6-week max is the longest subscription interval we offer)."
                    }
                }
            },
