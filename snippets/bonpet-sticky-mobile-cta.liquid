{%- comment -%}
  V3 Sticky mobile trial CTA — anchors to bottom of viewport on mobile only.
  Hides on trial PDPs + cart/checkout to avoid noise.
{%- endcomment -%}

{%- liquid
  assign hide_cta = false
  if template.name == 'cart'
    assign hide_cta = true
  endif
  if product.handle contains 'trial'
    assign hide_cta = true
  endif
  if product.handle contains 'free-dog' or product.handle contains 'free-cat'
    assign hide_cta = true
  endif
-%}

{%- unless hide_cta -%}
<button type="button"
  class="tbp-sticky-cta"
  aria-label="Claim your free trial pack"
  onclick="if(window.openBonPetForm){window.openBonPetForm();}else{window.location.href='/discount/FREETRIAL%253C3THEBONPET?redirect=%2Fproducts%2Ffree-dog-trial-pack';}">
  <span class="tbp-sticky-cta-emoji" aria-hidden="true">🎁</span>
  <span class="tbp-sticky-cta-label">Claim My Free Trial</span>
  <span class="tbp-sticky-cta-arrow" aria-hidden="true">→</span>
</button>

<style>
  .tbp-sticky-cta {
    display: inline-flex;
    position: fixed;
    left: var(--tbp-space-4);
    bottom: var(--tbp-space-4);
    background: linear-gradient(180deg, var(--tbp-primary-light) 0%, var(--tbp-primary-deep) 100%);
    color: var(--tbp-white);
    text-decoration: none;
    padding: 14px 22px;
    border-radius: var(--tbp-radius-pill);
    font-family: var(--tbp-font-body);
    font-weight: 700;
    font-size: 1rem;
    box-shadow: 0 8px 24px rgba(0,0,0,0.25);
    z-index: 100000;
    align-items: center;
    gap: 10px;
    white-space: nowrap;
    border: 2px solid var(--tbp-white-60);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    cursor: pointer;
  }
  .tbp-sticky-cta:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(0,0,0,0.3); }
  .tbp-sticky-cta-arrow { font-weight: 400; }
  @media (max-width: 480px) {
    .tbp-sticky-cta {
      left: var(--tbp-space-3);
      bottom: var(--tbp-space-3);
      padding: 12px 18px;
      font-size: 0.9rem;
    }
  }
</style>
{%- endunless -%}
